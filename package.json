{
  "name": "secure-vault",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "electron",
    "extension",
    "shared"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:electron": "npm run dev --workspace=electron",
    "build:extension": "npm run build --workspace=extension",
    "test": "npm run test --workspace=shared && npm run test --workspace=backend"
  }
}
